# Azure OpenAI – required
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-4o-realtime-preview
AZURE_OPENAI_REALTIME_VOICE_CHOICE=alloy

# Auth: API Key (simplest) – set this and you're done
AZURE_OPENAI_API_KEY=your-api-key-here

# Auth: Managed Identity / CLI (alternative – leave API_KEY empty)
# AZURE_TENANT_ID=your-tenant-id

# ── Azure AI Search (RAG) – required ──
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH.search.windows.net
AZURE_SEARCH_INDEX=your-index-name
AZURE_SEARCH_API_KEY=your-search-api-key

# Optional: Search-Konfiguration (Defaults passen für Standard-Indexe)
# AZURE_SEARCH_SEMANTIC_CONFIGURATION=my-semantic-config
# AZURE_SEARCH_IDENTIFIER_FIELD=chunk_id
# AZURE_SEARCH_CONTENT_FIELD=chunk
# AZURE_SEARCH_EMBEDDING_FIELD=text_vector
# AZURE_SEARCH_TITLE_FIELD=title
# AZURE_SEARCH_USE_VECTOR_QUERY=true
